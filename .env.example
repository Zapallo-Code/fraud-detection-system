# Kafka connectivity (used by app services)
KAFKA_BROKER_URL=kafka:29092  # Internal Kafka bootstrap server on mlops-net

# PostgreSQL (system metadata and MLflow backend)
POSTGRES_USER=fraud_metadata_user  # PostgreSQL application user
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD  # PostgreSQL password
POSTGRES_DB=fraud_metadata  # PostgreSQL metadata database name

# TimescaleDB (transaction time-series storage)
TIMESCALE_USER=fraud_timeseries_user  # TimescaleDB application user
TIMESCALE_PASSWORD=CHANGE_ME_TIMESCALE_PASSWORD  # TimescaleDB password
TIMESCALE_DB=fraud_transactions_timeseries  # TimescaleDB transaction database name

# MLflow tracking service
MLFLOW_TRACKING_URI=http://mlflow:5000  # Internal URI used by containers
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://fraud_metadata_user:CHANGE_ME_POSTGRES_PASSWORD@postgresql:5432/fraud_metadata  # MLflow usa su propia base; no compartir con Airflow (conflicto de Alembic)

# Airflow core and metadata database
AIRFLOW__CORE__EXECUTOR=LocalExecutor  # Airflow executor type
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://fraud_metadata_user:CHANGE_ME_POSTGRES_PASSWORD@postgresql:5432/airflow_metadata  # Airflow usa su propia base; no compartir con MLflow (conflicto de Alembic)
AIRFLOW__CORE__FERNET_KEY=CHANGE_ME_FERNET_KEY_BASE64  # Base64-encoded Fernet key
AIRFLOW_ADMIN_USER=admin  # Airflow admin username
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME_AIRFLOW_ADMIN_PASSWORD  # Airflow admin password

# Grafana admin credentials
GF_SECURITY_ADMIN_USER=admin  # Grafana admin username
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN_PASSWORD  # Grafana admin password
