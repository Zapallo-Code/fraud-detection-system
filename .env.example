# ── Kafka ──────────────────────────────────────────────────────
KAFKA_BROKER_URL=kafka:29092                          # Bootstrap server interno
KAFKA_SCHEMA_REGISTRY_URL=http://schema-registry:8081 # Schema Registry interno
KAFKA_TOPICS_RAW=transactions.raw                     # Transacciones crudas
KAFKA_TOPICS_FEATURES=transactions.features           # Features calculadas
KAFKA_TOPICS_PREDICTIONS=transactions.predictions     # Resultados del modelo
KAFKA_TOPICS_ALERTS=transactions.fraud.alerts         # Alertas de fraude

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_HOST=postgresql                              # Hostname en mlops-net
POSTGRES_PORT=5432
POSTGRES_USER=fraud_metadata_user
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=fraud_metadata

# ── TimescaleDB ────────────────────────────────────────────────
TIMESCALE_HOST=timescaledb                            # Hostname en mlops-net
TIMESCALE_PORT=5432
TIMESCALE_USER=fraud_timeseries_user
TIMESCALE_PASSWORD=CHANGE_ME_TIMESCALE_PASSWORD
TIMESCALE_DB=fraud_transactions_timeseries

# ── Redis ──────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── MLflow ─────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://fraud_metadata_user:CHANGE_ME_POSTGRES_PASSWORD@postgresql:5432/fraud_metadata
MLFLOW_EXPERIMENT_NAME=fraud-detection-v1

# ── FastAPI / Model serving ────────────────────────────────────
MODEL_NAME=FraudDetectionModel
MODEL_STAGE=Production
FRAUD_SCORE_THRESHOLD=0.5

# ── Airflow ────────────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://fraud_metadata_user:CHANGE_ME_POSTGRES_PASSWORD@postgresql:5432/airflow_metadata
AIRFLOW__CORE__FERNET_KEY=CHANGE_ME_FERNET_KEY_BASE64
AIRFLOW__WEBSERVER__SECRET_KEY=CHANGE_ME_AIRFLOW_WEBSERVER_SECRET
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME_AIRFLOW_ADMIN_PASSWORD

# ── Grafana ────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN_PASSWORD
