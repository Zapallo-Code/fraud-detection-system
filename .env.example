# -------------------------------------------------------------
# Fraud Detection System - Environment Variables Template
# Copy this file to .env and replace all CHANGE_ME values.
# -------------------------------------------------------------

# ==============================
# Global / Runtime
# ==============================
APP_ENV=development                    # development | staging | production
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
TZ=UTC                                 # System timezone

# ==============================
# Kafka / Streaming
# ==============================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092     # Internal broker address for containers
KAFKA_ADVERTISED_HOST=localhost         # External host for local access
KAFKA_ADVERTISED_PORT=9094              # External port for local access
KAFKA_SCHEMA_REGISTRY_URL=http://schema-registry:8081

KAFKA_TOPIC_TRANSACTIONS_RAW=transactions.raw
KAFKA_TOPIC_TRANSACTIONS_FEATURES=transactions.features
KAFKA_TOPIC_TRANSACTIONS_PREDICTIONS=transactions.predictions
KAFKA_TOPIC_TRANSACTIONS_FRAUD_ALERTS=transactions.fraud.alerts

KAFKA_CONSUMER_GROUP_FEATURE_ENGINEERING=fraud-feature-engineering
KAFKA_CONSUMER_GROUP_INFERENCE=fraud-inference
KAFKA_AUTO_OFFSET_RESET=latest          # earliest | latest

# ==============================
# TimescaleDB (time-series storage)
# ==============================
TIMESCALEDB_HOST=timescaledb
TIMESCALEDB_PORT=5432
TIMESCALEDB_DB=fraud_timeseries
TIMESCALEDB_USER=fraud_app
TIMESCALEDB_PASSWORD=CHANGE_ME_TIMESCALE_PASSWORD
TIMESCALEDB_SSLMODE=prefer              # disable | prefer | require
TIMESCALEDB_URL=postgresql://fraud_app:CHANGE_ME_TIMESCALE_PASSWORD@timescaledb:5432/fraud_timeseries

# ==============================
# PostgreSQL (system of record)
# ==============================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fraud_core
POSTGRES_USER=fraud_app
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_SSLMODE=prefer                 # disable | prefer | require
POSTGRES_URL=postgresql://fraud_app:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/fraud_core

# ==============================
# MLflow
# ==============================
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://fraud_app:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/fraud_core
MLFLOW_ARTIFACT_ROOT=/mlflow/artifacts

# Optional if artifact store is S3-compatible (e.g., MinIO)
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_KEY
AWS_DEFAULT_REGION=us-east-1
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# ==============================
# Airflow
# ==============================
AIRFLOW_UID=50000
AIRFLOW_GID=0

AIRFLOW__CORE__EXECUTOR=LocalExecutor   # LocalExecutor | CeleryExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__FERNET_KEY=CHANGE_ME_FERNET_KEY_BASE64
AIRFLOW__WEBSERVER__SECRET_KEY=CHANGE_ME_AIRFLOW_SECRET_KEY
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://fraud_app:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/fraud_core

_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=CHANGE_ME_AIRFLOW_ADMIN_PASSWORD
_AIRFLOW_WWW_USER_EMAIL=admin@example.com
_AIRFLOW_WWW_USER_FIRSTNAME=Fraud
_AIRFLOW_WWW_USER_LASTNAME=Admin

# Airflow Connections (for DAGs/operators)
AIRFLOW_CONN_POSTGRES_CONN=postgresql://fraud_app:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/fraud_core
AIRFLOW_CONN_TIMESCALEDB_CONN=postgresql://fraud_app:CHANGE_ME_TIMESCALE_PASSWORD@timescaledb:5432/fraud_timeseries
AIRFLOW_CONN_MLFLOW_CONN=http://mlflow:5000

# ==============================
# Serving (FastAPI)
# ==============================
SERVING_HOST=0.0.0.0
SERVING_PORT=8000
SERVING_WORKERS=1

SERVING_MODEL_NAME=FraudDetectionModel
SERVING_MODEL_STAGE=Production          # None | Staging | Production | Archived
SERVING_PREDICTION_THRESHOLD=0.80
SERVING_MAX_BATCH_SIZE=256

# ==============================
# Drift Detection (Evidently)
# ==============================
EVIDENTLY_DRIFT_THRESHOLD=0.30          # Trigger retrain when above threshold
EVIDENTLY_REFERENCE_WINDOW_DAYS=30
EVIDENTLY_CURRENT_WINDOW_HOURS=24

# ==============================
# Monitoring
# ==============================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN_PASSWORD
GRAFANA_HTTP_PORT=3000

PROMETHEUS_HTTP_PORT=9090

# ==============================
# Feature Store / Cache (optional)
# ==============================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0
